# Copy this file to .env and fill in your own values.
# .env is gitignored and must never be committed.

# Canvas
CANVAS_BASE_URL=https://canvas.example.edu/api/v1
CANVAS_TOKEN=your_canvas_token_here
COURSE_ID=000000
ASSIGNMENT_ID=000000
QUIZ_ID=000000

# GitHub (use a read-only fine grained or classic token, no write scopes)
GITHUB_TOKEN=ghp_your_read_only_token_here
GITHUB_ORG=your-org
REPO_PREFIX=course-labs-

# Grading parameters
LAB_NUMBER=4
DEADLINE_UTC=2026-05-04T06:59:00+00:00
MAX_SCORE=12
SHORT_ANSWER_IDS=
DRY_RUN=1
ROSTER=sample_data/roster.example.csv
